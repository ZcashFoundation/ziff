    return p
}
# Tidy a generic-argument string for display: drop lifetimes and shorten paths.
function short_gen(g) {
    gsub(/'\''[A-Za-z_][A-Za-z0-9_]* */, "", g)   # drop lifetimes (e.g. <"de"> on Deserialize)
