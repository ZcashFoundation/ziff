# Emit one module group (nested mod mode): module header, then each owning type
# as a sub-header with members, or module-level items directly.
function emit_module(m,   ti, t, k, disp, nm) {
    print "M\t" m
    for (ti = 1; ti <= tcnt[m]; ti++) {
        t = tlist[m, ti]
        if (t == m) {
            for (k = 1; k <= mcnt[t]; k++) {
                disp = buf[members[t, k]]
                gsub(m "::", "", disp)
